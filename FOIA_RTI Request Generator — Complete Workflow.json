        "sendTo": "={{ $('Set Config Variables').item.json.REQUESTER_EMAIL }}",
        "subject": "=Your FOIA/RTI Request Has Been Submitted — {{ $('Webhook — Receive FOIA Request').item.json.body.request_id }}",
        "message": "=<p>Dear {{ $('Webhook — Receive FOIA Request').item.json.body.requester_name }},</p><p>Your public records request has been successfully submitted. Here are the details:</p><table style='border-collapse: collapse; width: 100%;'><tr><td style='padding: 8px; border: 1px solid #ddd;'><strong>Request ID</strong></td><td style='padding: 8px; border: 1px solid #ddd;'>{{ $('Webhook — Receive FOIA Request').item.json.body.request_id }}</td></tr><tr><td style='padding: 8px; border: 1px solid #ddd;'><strong>Agency</strong></td><td style='padding: 8px; border: 1px solid #ddd;'>{{ $('Webhook — Receive FOIA Request').item.json.body.agency_name }}</td></tr><tr><td style='padding: 8px; border: 1px solid #ddd;'><strong>Agency Email</strong></td><td style='padding: 8px; border: 1px solid #ddd;'>{{ $('Webhook — Receive FOIA Request').item.json.body.agency_email }}</td></tr><tr><td style='padding: 8px; border: 1px solid #ddd;'><strong>Jurisdiction</strong></td><td style='padding: 8px; border: 1px solid #ddd;'>{{ $('Webhook — Receive FOIA Request').item.json.body.jurisdiction }}</td></tr><tr><td style='padding: 8px; border: 1px solid #ddd;'><strong>Date Sent</strong></td><td style='padding: 8px; border: 1px solid #ddd;'>{{ $('Webhook — Receive FOIA Request').item.json.body.date_sent }}</td></tr><tr><td style='padding: 8px; border: 1px solid #ddd;'><strong>Response Due</strong></td><td style='padding: 8px; border: 1px solid #ddd;'>{{ $('Webhook — Receive FOIA Request').item.json.body.response_due }}</td></tr><tr><td style='padding: 8px; border: 1px solid #ddd;'><strong>Subject</strong></td><td style='padding: 8px; border: 1px solid #ddd;'>{{ $('Webhook — Receive FOIA Request').item.json.body.subject }}</td></tr></table><p style='margin-top: 16px;'>The agency is required to respond by <strong>{{ $('Webhook — Receive FOIA Request').item.json.body.response_due }}</strong>. If no response is received by then, an automatic follow-up will be sent on your behalf.</p><p>A copy of your letter has been saved to: <code>{{ $('Webhook — Receive FOIA Request').item.json.body.output_file }}</code></p><hr><p style='color: #666; font-size: 12px;'>This is an automated notification from the FOIA/RTI Request Generator.</p>",
        "options": {}
